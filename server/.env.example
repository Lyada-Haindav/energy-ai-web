PORT=8787
ALLOWED_ORIGIN=http://localhost:5173

# Provider choice per role: mock | own | python_local | ollama | openai
ROUTER_PROVIDER=mock
FAST_PROVIDER=mock
DEEP_PROVIDER=mock

# Model names for each role
ROUTER_MODEL=energy-router-v1
FAST_MODEL=energy-low-v1
DEEP_MODEL=energy-high-v1

# Shared generation defaults
MAX_TOKENS=700
TEMPERATURE=0.4

# Own local model artifacts (used when provider=own)
OWN_MODELS_DIR=../training/checkpoints/own

# Local Python checkpoint server (used when provider=python_local)
PYTHON_LOCAL_BASE_URL=http://127.0.0.1:9001

# Ollama (if used)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI compatible endpoint (if used)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# App/auth/email
APP_BASE_URL=http://localhost:5173
BREVO_API_KEY=
EMAIL_FROM=your-verified-sender@example.com
EMAIL_FROM_NAME=Energy AI
